{
  "name": "pharos",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "npm run dev:frontend",
    "build": "npm run build:frontend",
    "dev:frontend": "pnpm --dir ../client-solid run dev",
    "build:frontend": "pnpm install --dir ../client-solid --frozen-lockfile && pnpm --dir ../client-solid run build",
    "preview": "pnpm --dir ../client-solid run preview",
    "icons": "tauri icon ../../assets/brand/pharos-mark-square.svg",
    "test:e2e": "pnpm install --dir ../client-solid --frozen-lockfile && pnpm --dir ../client-solid run build && pnpm --dir ../client-solid run test:e2e",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "^2"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2"
  }
}
