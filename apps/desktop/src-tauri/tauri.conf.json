{
  "productName": "Pharos Agent Monitor",
  "version": "0.1.0",
  "identifier": "com.pharos.agent-monitor",
  "build": {
    "frontendDist": "../../client-solid/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "cd ../client-solid && pnpm dev",
    "beforeBuildCommand": "cd ../client-solid && pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Pharos Agent Monitor",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ]
  }
}
